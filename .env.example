# Copia questo file come .env e compila i valori.
# Le credenziali si trovano nella dashboard Supabase: Settings > API.
# IMPORTANTE: la VITE_SUPABASE_ANON_KEY è progettata per essere pubblica
# (finisce nel bundle JS), ma NON committarla mai per pulizia operativa.
# La service_role key NON va MAI nel frontend, solo nelle Edge Functions.

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
